# Skopiuj ten plik do .env i uzupełnij wartości (.env jest w .gitignore)

# Neon PostgreSQL — POOLED connection string (host z "-pooler"); używany w runtime przez aplikację
# Format: postgresql://USER:PASSWORD@ep-xxxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Neon DIRECT connection string (host BEZ "-pooler"); używany do migracji / prisma db push
# Format: postgresql://USER:PASSWORD@ep-xxxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
DIRECT_URL=

# Sekret do podpisywania JWT — wygeneruj np.:  openssl rand -base64 32
JWT_SECRET=

# development | production  (steruje flagą Secure na cookie)
NODE_ENV=development

# Port lokalnego serwera backendu (opcjonalne, domyślnie 3001)
PORT=3001

# Klucz Anthropic (Claude API) — wyszukiwarka kodu celnego AI w kroku 2 kreatora.
# WYŁĄCZNIE po stronie serwera (nigdy w bundlu frontendu). Ustaw też w env Vercela.
ANTHROPIC_API_KEY=
