// Prisma schema dla AmLogistico
// Baza: PostgreSQL (Neon). Connection string w env DATABASE_URL.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (z "-pooler") — zapytania aplikacji w runtime
  directUrl = env("DIRECT_URL")   // direct (bez "-pooler") — migracje / db push
}

// users — konta użytkowników (zgodne z docs/3.Baza danych.md)
model User {
  id               String    @id @default(uuid())
  email            String    @unique
  passwordHash     String    @map("password_hash")
  companyName      String?   @map("company_name") // opcjonalne — rejestracja nie wymaga firmy
  vatNumber        String?   @map("vat_number")
  plan             String    @default("free") // free / monthly / pay_per_doc
  planExpiresAt    DateTime? @map("plan_expires_at")
  stripeCustomerId String?   @map("stripe_customer_id")
  createdAt        DateTime  @default(now()) @map("created_at")

  // Dane podstawowe zbierane przy rejestracji (nullable w bazie — tabela ma już
  // rekordy; wymagalność egzekwuje Zod, nie schemat)
  fullName         String?   @map("full_name")
  phone            String?
  termsAcceptedAt  DateTime? @map("terms_accepted_at")
  marketingConsent Boolean   @default(false) @map("marketing_consent")

  // Profil rozszerzony — zawsze opcjonalny (auto-fill nadawcy w kreatorze)
  profileCompleted  Boolean  @default(false) @map("profile_completed")
  eoriNumber        String?  @map("eori_number")
  address           String?
  city              String?
  postalCode        String?  @map("postal_code")
  country           String?
  defaultCurrency   String?  @map("default_currency")
  preferredLanguage String?  @default("PL") @map("preferred_language")

  // Uprawnienie administratora (wysyłanie powiadomień). Nadawane ręcznie w Prisma
  // Studio — brak UI do zarządzania adminami (MVP).
  isAdmin           Boolean  @default(false) @map("is_admin")

  documentSets  DocumentSet[]
  notifications Notification[]

  @@map("users")
}

// notifications — powiadomienia w aplikacji (dzwonek). Wysyłane przez admina na
// konkretne konto lub do wszystkich (fan-out: osobny wiersz na użytkownika).
model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String    @default("info") // info | success | warning
  title     String
  body      String
  ctaLabel  String?   @map("cta_label") // etykieta przycisku (opcjonalnie)
  ctaUrl    String?   @map("cta_url")   // link przycisku (opcjonalnie)

  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@map("notifications")
}

// document_sets — zapisane komplety dokumentów (migawka formData, NIE pliki PDF).
// Kształt kolumn odwzorowuje obiekt z src/services/documentSetsRepo.js, żeby
// mapowanie repo ⇄ baza było 1:1. PDF-y regenerujemy z form_data na żądanie.
model DocumentSet {
  id             String  @id @default(uuid())
  userId         String  @map("user_id")
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  status         String  // "draft" | "completed"
  kind           String? // np. "blank" dla setów z pustych szablonów (domyślnie null)
  flowType       String  @map("flow_type") // have_transport | find_transport | blank_templates
  totalSteps     Int     @map("total_steps")
  derivedFromId  String? @map("derived_from_id") // edycja completed → id oryginału

  lastStep       Int     @map("last_step")
  maxStepReached Int     @map("max_step_reached")

  templateVersion String @map("template_version") // wersja szablonów użyta przy secie

  // Migawki serializowane jako JSON (repo trzyma je jako obiekty).
  formData       Json    @map("form_data")     // cały snapshot kreatora
  engineResult   Json?   @map("engine_result") // wynik doboru dokumentów
  selectedDocs   Json    @map("selected_docs") // klucze wygenerowanych dokumentów
  meta           Json    // metadane karty/wyszukiwarki (trasa, tryb, opis, data)

  // Płaskie kolumny do szybkich zapytań listy (bez ładowania form_data).
  transportMode  String? @map("transport_mode")
  countryFrom    String? @map("country_from")
  countryTo      String? @map("country_to")

  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([userId, status])
  @@map("document_sets")
}

// cn_codes — nomenklatura CN/TARIC z ISZTAR4 (Ministerstwo Finansów). Źródło prawdy
// dla walidacji kodów celnych podkategorii towaru. Zasilane WYŁĄCZNIE offline przez
// scripts/sync-isztar.js (nigdy z requestu użytkownika).
//
// Uwagi o rozbieżności model⇄API (rekonesans 2026-07-23):
//  - ISZTAR endpoint `codes?date=` zwraca DRZEWO aktywne na dany dzień, bez jawnych
//    dat obowiązywania per kod. Dlatego `validFrom` = data pierwszej synchronizacji,
//    a `validTo` ustawiamy dopiero, gdy kod ZNIKNIE z API w kolejnym przebiegu
//    (kodów NIE kasujemy — historyczne są potrzebne do starych dokumentów).
//  - API emituje `code` tylko dla poziomów 6-cyfrowego (podpozycja CN) i 10-cyfrowego
//    (TARIC). Poziomy 2/4 (dział/pozycja) są węzłami bez `code` — nie zapisujemy ich.
//    Kod CN8 z bazy podkategorii waliduje się jako PREFIKS aktywnego kodu 10-cyfrowego.
model CnCode {
  code          String    @id                 // kod bez kropek (6 lub 10 cyfr)
  cn8           String    @map("cn8")          // pierwsze ≤8 cyfr kodu (do dopasowań CN8)
  parentCode    String?   @map("parent_code")  // najbliższy kod nadrzędny w drzewie
  level         Int                            // długość kodu (6 lub 10)
  descriptionPl String    @map("description_pl")
  descriptionEn String?   @map("description_en")
  validFrom     DateTime  @map("valid_from")   // data pierwszej synchronizacji (nie realna data KE)
  validTo       DateTime? @map("valid_to")     // ustawiane, gdy kod zniknie z ISZTAR
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@index([cn8])
  @@index([descriptionPl])
  @@map("cn_codes")
}

// hs_suggestion_cache — cache wyników wyszukiwarki kodu celnego AI (krok 2 kreatora).
// Klucz = sha256(lowercase(trim(description)) + countryFrom + countryTo). TTL 90 dni
// egzekwowane w kodzie (po createdAt). Trafienie w cache = zero wywołań Claude API.
model HsSuggestionCache {
  key           String   @id // sha256 hex
  description   String
  countryFrom   String   @map("country_from")
  countryTo     String   @map("country_to")
  result        Json     // pełna odpowiedź zwracana frontendowi (suggestions, destination, ...)
  usedWebSearch Boolean  @default(false) @map("used_web_search")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("hs_suggestion_cache")
}

// hs_choice_log — który kod user FAKTYCZNIE wybrał („Użyj") spośród sugestii AI.
// Do oceny skuteczności wyszukiwarki po wdrożeniu (czy user bierze pierwszą sugestię,
// czy dalszą, czy w ogóle). userId to plain string (bez relacji — to log analityczny).
model HsChoiceLog {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  description    String
  countryFrom    String   @map("country_from")
  countryTo      String   @map("country_to")
  chosenCode     String   @map("chosen_code")
  source         String   // 'classify' (CN8/HS-6) | 'destination' (kraj docelowy)
  verified       Boolean? // dla source=destination: czy kod był zweryfikowany źródłem
  suggestedCodes Json     @map("suggested_codes") // kody pokazane userowi (ocena trafności)
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("hs_choice_log")
}
