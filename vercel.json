{
  "rewrites": [
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/sync-isztar", "schedule": "0 4 * * 1" }
  ],
  "functions": {
    "api/index.js": { "maxDuration": 60 }
  }
}
